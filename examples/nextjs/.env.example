# The school domain you registered your OAuth app against.
# Example: demo.teachify.tw  (do NOT include https://)
LOOPWISE_SCHOOL_DOMAIN=demo.teachify.tw

# OAuth client credentials from the Loopwise Connect developer portal.
LOOPWISE_CLIENT_ID=your_client_id_here
LOOPWISE_CLIENT_SECRET=your_client_secret_here

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=replace_with_a_random_secret

# The public URL of this Next.js app.
AUTH_URL=http://localhost:3000
